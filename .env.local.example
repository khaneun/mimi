# .env.local — 로컬 개발 전용 시크릿 파일
# 이 파일을 복사하여 .env.local 생성 후 실제 값을 입력하세요.
# .env.local은 .gitignore에 의해 git에 포함되지 않습니다.
#
# EC2 배포 환경에서는 이 파일이 필요 없습니다.
# 모든 시크릿은 AWS Secrets Manager 'mimi/production'에서 자동 로드됩니다.
#
# LLM: Claude Code CLI 전용 (API 키 불필요)
#       현재 로그인된 Claude 계정 토큰을 자동 사용합니다.

# KRX 로그인
KRX_ID=your_krx_id
KRX_PW=your_krx_password

# KIS 모의투자
KIS_PAPER_APP_KEY=PSVTxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIS_PAPER_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIS_PAPER_ACCOUNT=12345678

# KIS 실전투자
KIS_REAL_APP_KEY=PSxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIS_REAL_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIS_REAL_ACCOUNT=87654321

# KIS 공통
KIS_HTS_ID=your_hts_id

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_AI_BOT_TOKEN=your_ai_bot_token
